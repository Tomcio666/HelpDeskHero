@page "/tickets/create"
@attribute [Authorize(Roles = "Admin,Agent")]

@inject HelpDeskHero.UI.Services.Api.TicketApiClient TicketApi
@inject NavigationManager Nav

<h3>Nowe zgłoszenie</h3>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<EditForm Model="_model" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Tytuł</label>
        <InputText class="form-control" @bind-Value="_model.Title" />
    </div>

    <div class="mb-3">
        <label>Opis</label>
        <InputTextArea class="form-control" @bind-Value="_model.Description" />
    </div>

    <div class="mb-3">
        <label>Priorytet</label>
        <InputSelect class="form-select" @bind-Value="_model.Priority">
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
        </InputSelect>
    </div>

    <button class="btn btn-primary" disabled="@_busy">Zapisz</button>
</EditForm>

@code {
    private CreateTicketDto _model = new();
    private bool _busy;
    private string? _error;

    private async Task SaveAsync()
    {
        _busy = true;
        _error = null;

        var response = await TicketApi.CreateAsync(_model);

        _busy = false;

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/tickets");
            return;
        }

        _error = "Nie udało się utworzyć zgłoszenia.";
    }
}