@page "/tickets"
@attribute [Authorize]

@using HelpDeskHero.Shared.Contracts.Common
@using HelpDeskHero.Shared.Contracts.Tickets
@inject HelpDeskHero.UI.Services.Api.TicketApiClient TicketApi

<h3>Zgłoszenia</h3>

<div class="row g-2 mb-3">
    <div class="col-md-4">
        <InputText class="form-control" @bind-Value="_query.Search" placeholder="Szukaj..." />
    </div>
    <div class="col-md-2">
        <InputSelect class="form-select" @bind-Value="_query.Status">
            <option value="">Wszystkie statusy</option>
            <option value="New">New</option>
            <option value="InProgress">InProgress</option>
            <option value="Closed">Closed</option>
        </InputSelect>
    </div>
    <div class="col-md-2">
        <InputSelect class="form-select" @bind-Value="_query.Priority">
            <option value="">Wszystkie priorytety</option>
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
        </InputSelect>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" @onclick="ReloadAsync">Filtruj</button>
    </div>
</div>

@if (_result is null)
{
    <p>Ładowanie...</p>
}
else
{
    <p>Łącznie: @_result.TotalCount</p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nr</th>
                <th>Tytuł</th>
                <th>Status</th>
                <th>Priorytet</th>
                <th>Utworzono</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _result.Items)
            {
                <tr>
                    <td>@item.Number</td>
                    <td><a href="@($"/tickets/edit/{item.Id}")">@item.Title</a></td>
                    <td>@item.Status</td>
                    <td>@item.Priority</td>
                    <td>@item.CreatedAtUtc.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" disabled="@(_query.PageNumber <= 1)" @onclick="PrevAsync">Poprzednia</button>
        <span>Strona @_query.PageNumber</span>
        <button class="btn btn-outline-secondary"
                disabled="@((_query.PageNumber * _query.PageSize) >= _result.TotalCount)"
                @onclick="NextAsync">
            Następna
        </button>
    </div>
}

@code {
    private TicketQueryDto _query = new();
    private PagedResultDto<TicketDto>? _result;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _result = await TicketApi.GetPageAsync(_query);
    }

    private async Task PrevAsync()
    {
        if (_query.PageNumber > 1)
        {
            _query.PageNumber--;
            await ReloadAsync();
        }
    }

    private async Task NextAsync()
    {
        _query.PageNumber++;
        await ReloadAsync();
    }
}